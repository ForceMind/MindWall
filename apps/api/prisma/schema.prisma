generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  onboarding
  active
  restricted
}

enum UserTagType {
  PUBLIC_VISIBLE
  HIDDEN_SYSTEM
}

enum MatchStatus {
  pending
  active_sandbox
  wall_broken
  rejected
}

enum AiAction {
  passed
  blocked
  modified
}

enum OnboardingSessionStatus {
  in_progress
  completed
  blocked
}

model User {
  id               String           @id @default(uuid()) @db.Uuid
  auth_provider_id String           @unique
  status           UserStatus       @default(onboarding)
  created_at       DateTime         @default(now())
  profile          UserProfile?
  credential       UserCredential?
  sessions         AuthSession[]
  tags             UserTag[]
  ai_logs          AiGenerationLog[]
  interview_records OnboardingInterviewRecord[]
  interview_sessions OnboardingInterviewSession[]
  matches_a        Match[]          @relation("MatchUserA")
  matches_b        Match[]          @relation("MatchUserB")
  sent_messages    SandboxMessage[] @relation("SentMessages")

  @@index([status])
  @@map("users")
}

model UserCredential {
  user_id        String   @id @db.Uuid
  username       String   @unique @map("email") @db.VarChar(320)
  password_hash  String   @db.Text
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_credentials")
}

model AuthSession {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  token_hash String   @unique @db.VarChar(64)
  expires_at DateTime
  last_seen_at DateTime @default(now())
  revoked_at DateTime?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@index([last_seen_at])
  @@index([token_hash])
  @@map("auth_sessions")
}

model UserProfile {
  user_id        String   @id @db.Uuid
  real_avatar    String?
  real_name      String?
  anonymous_avatar String?
  anonymous_name String?  @db.VarChar(64)
  gender         String?  @db.VarChar(16)
  age            Int?
  city           String?  @db.VarChar(128)
  is_wall_broken Boolean  @default(false)
  updated_at     DateTime @updatedAt
  created_at     DateTime @default(now())
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([city])
  @@map("user_profiles")
}

model UserTag {
  id               String                       @id @default(uuid()) @db.Uuid
  user_id          String                       @db.Uuid
  type             UserTagType
  tag_name         String
  weight           Float
  ai_justification String                       @db.Text
  embedding        Unsupported("vector(1536)")?
  created_at       DateTime                     @default(now())
  user             User                         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, type, tag_name])
  @@index([user_id, type])
  @@index([tag_name])
  @@map("user_tags")
}

model Match {
  id              String           @id @default(uuid()) @db.Uuid
  user_a_id       String           @db.Uuid
  user_b_id       String           @db.Uuid
  status          MatchStatus      @default(pending)
  resonance_score Int              @default(0)
  ai_match_reason String?          @db.Text
  wall_break_consents Json?
  wall_broken_at    DateTime?
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  user_a          User             @relation("MatchUserA", fields: [user_a_id], references: [id], onDelete: Cascade)
  user_b          User             @relation("MatchUserB", fields: [user_b_id], references: [id], onDelete: Cascade)
  messages        SandboxMessage[]

  @@unique([user_a_id, user_b_id])
  @@index([status])
  @@index([user_a_id, status])
  @@index([user_b_id, status])
  @@map("matches")
}

model SandboxMessage {
  id                 String   @id @default(uuid()) @db.Uuid
  match_id           String   @db.Uuid
  sender_id          String   @db.Uuid
  original_text      String   @db.Text
  ai_rewritten_text  String   @db.Text
  ai_action          AiAction
  hidden_tag_updates Json?
  created_at         DateTime @default(now())
  match              Match    @relation(fields: [match_id], references: [id], onDelete: Cascade)
  sender             User     @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([match_id, created_at])
  @@index([sender_id, created_at])
  @@map("sandbox_messages")
}

model AiGenerationLog {
  id                 String   @id @default(uuid()) @db.Uuid
  user_id            String?  @db.Uuid
  feature            String   @db.VarChar(64)
  prompt_key         String?  @db.VarChar(64)
  provider           String   @default("openai") @db.VarChar(32)
  model              String   @db.VarChar(128)
  input_tokens       Int      @default(0)
  output_tokens      Int      @default(0)
  total_tokens       Int      @default(0)
  estimated_cost_usd Decimal  @default(0) @db.Decimal(12, 6)
  metadata           Json?
  created_at         DateTime @default(now())
  user               User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([feature, created_at])
  @@index([user_id, created_at])
  @@map("ai_generation_logs")
}

model PromptTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @unique @db.VarChar(64)
  name         String   @db.VarChar(128)
  category     String   @db.VarChar(64)
  content      String   @db.Text
  version      Int      @default(1)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([category, is_active])
  @@map("prompt_templates")
}

model OnboardingInterviewRecord {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  session_id String   @db.Uuid
  turn_index Int
  role       String   @db.VarChar(16)
  content    String   @db.Text
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([session_id, turn_index])
  @@index([user_id, created_at])
  @@index([session_id, created_at])
  @@map("onboarding_interview_records")
}

model OnboardingInterviewSession {
  id                    String                  @id @db.Uuid
  user_id               String                  @db.Uuid
  status                OnboardingSessionStatus @default(in_progress)
  answer_count          Int                     @default(0)
  total_questions       Int                     @default(4)
  invalid_attempt_count Int                     @default(0)
  created_at            DateTime                @default(now())
  updated_at            DateTime                @updatedAt
  completed_at          DateTime?
  user                  User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, status, updated_at])
  @@index([status, updated_at])
  @@map("onboarding_interview_sessions")
}
