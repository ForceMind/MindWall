#!/usr/bin/env bash
set -euo pipefail

SELF="${BASH_SOURCE[0]:-$0}"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$SELF" 2>/dev/null || echo "$SELF")"
fi

ROOT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
DEPLOY_SCRIPT="$ROOT_DIR/deploy.sh"
UPDATE_SCRIPT="$ROOT_DIR/update.sh"
VERSION_FILE="$ROOT_DIR/VERSION"
RUNTIME_PORTS_FILE="$ROOT_DIR/.mw-runtime/ports.env"

COMMAND="${1:-auto}"
if [[ $# -gt 0 ]]; then
  shift
fi

# 兼容 mw --yes 这种写法
if [[ "${COMMAND#--}" != "$COMMAND" ]]; then
  set -- "$COMMAND" "$@"
  COMMAND="auto"
fi

project_version() {
  if [[ -f "$VERSION_FILE" ]]; then
    tr -d '[:space:]' < "$VERSION_FILE"
  else
    echo "未知"
  fi
}

usage() {
  cat <<'EOF'
MindWall 终端命令面板

用法:
  mw                     自动模式（已部署则更新，未部署则安装）
  mw auto                同上
  mw deploy [参数]       首次部署/完整部署
  mw update [参数]       快速更新
  mw status              查看运行状态
  mw logs                查看 API 实时日志
  mw menu                打开交互菜单
  mw help                查看帮助
EOF
}

load_ports() {
  API_PORT=""
  WEB_PORT=""
  if [[ -f "$RUNTIME_PORTS_FILE" ]]; then
    API_PORT="$(grep -E '^API_PORT=' "$RUNTIME_PORTS_FILE" | tail -n 1 | cut -d= -f2- || true)"
    WEB_PORT="$(grep -E '^WEB_PORT=' "$RUNTIME_PORTS_FILE" | tail -n 1 | cut -d= -f2- || true)"
  fi
}

is_installed() {
  [[ -f /etc/systemd/system/mindwall-api.service ]] || return 1
  [[ -f "$UPDATE_SCRIPT" ]] || return 1
  [[ -f "$DEPLOY_SCRIPT" ]] || return 1
  return 0
}

run_deploy() {
  [[ -f "$DEPLOY_SCRIPT" ]] || { echo "错误: 缺少 $DEPLOY_SCRIPT"; exit 1; }
  exec bash "$DEPLOY_SCRIPT" "$@"
}

run_update() {
  [[ -f "$UPDATE_SCRIPT" ]] || { echo "错误: 缺少 $UPDATE_SCRIPT"; exit 1; }
  exec bash "$UPDATE_SCRIPT" "$@"
}

show_status() {
  echo "MindWall v$(project_version)"
  echo "目录: $ROOT_DIR"
  load_ports
  if [[ -n "${WEB_PORT:-}" ]]; then
    echo "Web 端口: $WEB_PORT"
  fi
  if [[ -n "${API_PORT:-}" ]]; then
    echo "API 端口: $API_PORT"
  fi
  echo

  if command -v systemctl >/dev/null 2>&1; then
    if systemctl is-active --quiet mindwall-api 2>/dev/null; then
      echo "API 服务: 运行中"
    else
      echo "API 服务: 未运行"
    fi
    if systemctl is-active --quiet nginx 2>/dev/null; then
      echo "Nginx 服务: 运行中"
    else
      echo "Nginx 服务: 未运行"
    fi
  else
    echo "systemd: 不可用"
  fi

  if command -v docker >/dev/null 2>&1; then
    if docker info >/dev/null 2>&1; then
      echo "Docker: 可用"
    else
      echo "Docker: 已安装但引擎不可用"
    fi
  else
    echo "Docker: 未安装"
  fi
}

show_logs() {
  if ! command -v journalctl >/dev/null 2>&1; then
    echo "错误: 当前系统不支持 journalctl"
    exit 1
  fi
  exec journalctl -u mindwall-api -f
}

show_menu() {
  while true; do
    cat <<'EOF'

========== MindWall 菜单 ==========
1) 自动执行（推荐）
2) 首次部署
3) 快速更新
4) 查看状态
5) 查看 API 日志
6) 退出
===================================
EOF
    read -r -p "请选择 [1-6]: " choice
    case "$choice" in
      1) bash "$ROOT_DIR/mw" auto ;;
      2) bash "$ROOT_DIR/mw" deploy ;;
      3) bash "$ROOT_DIR/mw" update ;;
      4) bash "$ROOT_DIR/mw" status ;;
      5) bash "$ROOT_DIR/mw" logs ;;
      6) exit 0 ;;
      *) echo "无效选项，请重试。" ;;
    esac
  done
}

case "$COMMAND" in
  auto)
    if is_installed; then
      echo "检测到已部署环境，执行更新流程。"
      run_update "$@"
    else
      echo "检测到未部署环境，执行首次部署。"
      run_deploy "$@"
    fi
    ;;
  deploy|install)
    run_deploy "$@"
    ;;
  update)
    run_update "$@"
    ;;
  status)
    show_status
    ;;
  logs)
    show_logs
    ;;
  menu)
    show_menu
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "错误: 未识别命令 $COMMAND"
    usage
    exit 1
    ;;
esac
