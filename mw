#!/usr/bin/env bash
if head -n 1 "$0" | grep -q $'\r'; then
  sed -i 's/\r$//' "$0"
  exec bash "$0" "$@"
fi

set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

SELF="${BASH_SOURCE[0]:-$0}"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$SELF" 2>/dev/null || echo "$SELF")"
fi

ROOT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
DEPLOY_SCRIPT="$ROOT_DIR/deploy.sh"
UPDATE_SCRIPT="$ROOT_DIR/update.sh"
UNINSTALL_SCRIPT="$ROOT_DIR/uninstall.sh"
VERSION_FILE="$ROOT_DIR/VERSION"
RUNTIME_PORTS_FILE="$ROOT_DIR/.mw-runtime/ports.env"

COMMAND="${1:-auto}"
if [[ $# -gt 0 ]]; then
  shift
fi

if [[ "${COMMAND#--}" != "$COMMAND" ]]; then
  set -- "$COMMAND" "$@"
  COMMAND="auto"
fi

project_version() {
  if [[ -f "$VERSION_FILE" ]]; then
    tr -d '[:space:]' < "$VERSION_FILE"
  else
    echo "unknown"
  fi
}

usage() {
  cat <<EOF
有间 终端面板 v$(project_version)

用法:
  mw                          自动模式（已安装则 update，否则 deploy）
  mw deploy [参数]            首次部署/完整部署
  mw update [参数]            快速更新
  mw status                   查看服务与端口状态
  mw restart                  重启 API + Web
  mw stop                     停止 API + Web
  mw logs [api|web]           查看日志（默认 api）
  mw backup                   备份运行配置
  mw uninstall [参数]         卸载
  mw menu                     打开交互菜单
  mw help                     显示帮助
EOF
}

run_as_root() {
  if [[ "$(id -u)" -eq 0 ]]; then
    "$@"
    return $?
  fi
  if command -v sudo >/dev/null 2>&1; then
    sudo "$@"
    return $?
  fi
  echo "错误: 需要 root 权限且系统未安装 sudo" >&2
  return 1
}

load_ports() {
  API_PORT=""
  WEB_PORT=""
  PG_PORT=""
  REDIS_PORT=""

  if [[ -f "$RUNTIME_PORTS_FILE" ]]; then
    API_PORT="$(grep -E '^API_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    WEB_PORT="$(grep -E '^WEB_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    PG_PORT="$(grep -E '^PG_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    REDIS_PORT="$(grep -E '^REDIS_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
  fi
}

is_installed() {
  [[ -f /etc/systemd/system/mindwall-api.service ]] && [[ -f "$DEPLOY_SCRIPT" ]]
}

service_status_text() {
  local service_name="$1"
  if ! command -v systemctl >/dev/null 2>&1; then
    echo -e "${YELLOW}未知${NC}"
    return
  fi
  if systemctl is-active --quiet "$service_name" 2>/dev/null; then
    echo -e "${GREEN}运行中${NC}"
  else
    echo -e "${RED}未运行${NC}"
  fi
}

run_deploy() {
  [[ -f "$DEPLOY_SCRIPT" ]] || { echo "错误: 未找到 $DEPLOY_SCRIPT"; exit 1; }
  exec bash "$DEPLOY_SCRIPT" "$@"
}

run_update() {
  [[ -f "$UPDATE_SCRIPT" ]] || { echo "错误: 未找到 $UPDATE_SCRIPT"; exit 1; }
  exec bash "$UPDATE_SCRIPT" "$@"
}

run_uninstall() {
  [[ -f "$UNINSTALL_SCRIPT" ]] || { echo "错误: 未找到 $UNINSTALL_SCRIPT"; exit 1; }
  exec bash "$UNINSTALL_SCRIPT" "$@"
}

show_status() {
  load_ports

  echo
  echo -e "${CYAN}${BOLD}有间 v$(project_version) 状态${NC}"
  echo "目录: $ROOT_DIR"
  echo

  echo -e "  mindwall-api: $(service_status_text mindwall-api)    端口: ${API_PORT:-未记录}"
  echo -e "  mindwall-web: $(service_status_text mindwall-web)    端口: ${WEB_PORT:-未记录}"

  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    local pg_status="${RED}未运行${NC}"
    local redis_status="${RED}未运行${NC}"
    docker inspect --format '{{.State.Status}}' mindwall-postgres 2>/dev/null | grep -q running && pg_status="${GREEN}运行中${NC}"
    docker inspect --format '{{.State.Status}}' mindwall-redis 2>/dev/null | grep -q running && redis_status="${GREEN}运行中${NC}"
    echo -e "  PostgreSQL:  $pg_status    端口: ${PG_PORT:-未记录}"
    echo -e "  Redis:       $redis_status    端口: ${REDIS_PORT:-未记录}"
  fi

  if [[ -n "$WEB_PORT" ]]; then
    local ip
    ip="$(hostname -I 2>/dev/null | awk '{print $1}' || echo '127.0.0.1')"
    echo
    echo -e "  Web 访问地址: ${CYAN}http://${ip}:${WEB_PORT}${NC}"
  fi
  echo
}

show_logs() {
  local target="${1:-api}"
  if ! command -v journalctl >/dev/null 2>&1; then
    echo "错误: 系统没有 journalctl" >&2
    exit 1
  fi

  case "$target" in
    api) exec journalctl -u mindwall-api -f ;;
    web) exec journalctl -u mindwall-web -f ;;
    *) echo "用法: mw logs [api|web]"; exit 1 ;;
  esac
}

do_restart() {
  echo -e "${CYAN}正在重启 有间 服务...${NC}"
  if ! command -v systemctl >/dev/null 2>&1; then
    echo "错误: systemctl 不可用" >&2
    exit 1
  fi
  run_as_root systemctl restart mindwall-api 2>/dev/null || true
  run_as_root systemctl restart mindwall-web 2>/dev/null || true
  sleep 2
  show_status
}

do_stop() {
  echo -e "${CYAN}正在停止 有间 服务...${NC}"
  if ! command -v systemctl >/dev/null 2>&1; then
    echo "错误: systemctl 不可用" >&2
    exit 1
  fi
  run_as_root systemctl stop mindwall-api 2>/dev/null || true
  run_as_root systemctl stop mindwall-web 2>/dev/null || true
  echo -e "${GREEN}已停止。${NC}"
}

do_backup() {
  local ts
  ts="$(date +%Y%m%d-%H%M%S)"
  local target="$ROOT_DIR/.mw-runtime/backups/manual-$ts"
  mkdir -p "$target"

  [[ -f "$ROOT_DIR/apps/api/.env" ]] && cp "$ROOT_DIR/apps/api/.env" "$target/api.env"
  [[ -f "$ROOT_DIR/apps/web/.env.production.local" ]] && cp "$ROOT_DIR/apps/web/.env.production.local" "$target/web.env.production.local"
  [[ -f "$RUNTIME_PORTS_FILE" ]] && cp "$RUNTIME_PORTS_FILE" "$target/ports.env"

  echo -e "${GREEN}备份完成: $target${NC}"
}

show_menu() {
  while true; do
    echo
    echo -e "${CYAN}${BOLD}======== 有间 终端面板 ========${NC}"
    echo "  1) 自动执行（部署或更新）"
    echo "  2) 首次部署"
    echo "  3) 快速更新"
    echo "  4) 查看状态"
    echo "  5) 重启服务"
    echo "  6) 停止服务"
    echo "  7) 查看 API 日志"
    echo "  8) 查看 Web 日志"
    echo "  9) 备份配置"
    echo "  10) 卸载"
    echo "  0) 退出"
    echo -e "${CYAN}${BOLD}===================================${NC}"

    read -r -p "请选择 [0-10]: " choice
    case "$choice" in
      1) bash "$ROOT_DIR/mw" auto ;;
      2) bash "$ROOT_DIR/mw" deploy ;;
      3) bash "$ROOT_DIR/mw" update ;;
      4) show_status ;;
      5) do_restart ;;
      6) do_stop ;;
      7) show_logs api ;;
      8) show_logs web ;;
      9) do_backup ;;
      10) bash "$ROOT_DIR/mw" uninstall ;;
      0) exit 0 ;;
      *) echo -e "${YELLOW}输入无效，请重试。${NC}" ;;
    esac
  done
}

case "$COMMAND" in
  auto)
    if is_installed; then
      echo -e "检测到已安装，执行 ${GREEN}update${NC}..."
      run_update "$@"
    else
      echo -e "检测到未安装，执行 ${GREEN}deploy${NC}..."
      run_deploy "$@"
    fi
    ;;
  deploy|install)
    run_deploy "$@"
    ;;
  update)
    run_update "$@"
    ;;
  uninstall)
    run_uninstall "$@"
    ;;
  status)
    show_status
    ;;
  restart)
    do_restart
    ;;
  stop)
    do_stop
    ;;
  logs)
    show_logs "${1:-api}"
    ;;
  backup)
    do_backup
    ;;
  menu)
    show_menu
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo -e "${RED}未知命令: $COMMAND${NC}"
    usage
    exit 1
    ;;
esac
