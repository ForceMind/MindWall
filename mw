#!/usr/bin/env bash
# MindWall 缁堢鍛戒护闈㈡澘 v2.0
# 瀛︿範鑷?Minimal-Server-Deploy 鐨?zt.sh 鑿滃崟寮忕鐞?head -1 "$0"|grep -q $'\r'&&sed -i 's/\r$//' "$0"&&exec bash "$0" "$@" #
set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

SELF="${BASH_SOURCE[0]:-$0}"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$SELF" 2>/dev/null || echo "$SELF")"
fi

ROOT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
DEPLOY_SCRIPT="$ROOT_DIR/deploy.sh"
UPDATE_SCRIPT="$ROOT_DIR/update.sh"
UNINSTALL_SCRIPT="$ROOT_DIR/uninstall.sh"
VERSION_FILE="$ROOT_DIR/VERSION"
RUNTIME_PORTS_FILE="$ROOT_DIR/.mw-runtime/ports.env"

COMMAND="${1:-auto}"
if [[ $# -gt 0 ]]; then shift; fi

# 鍏煎: mw --yes => mw auto --yes
if [[ "${COMMAND#--}" != "$COMMAND" ]]; then
  set -- "$COMMAND" "$@"
  COMMAND="auto"
fi

project_version() {
  [[ -f "$VERSION_FILE" ]] && tr -d '[:space:]' < "$VERSION_FILE" || echo "鏈煡"
}

usage() {
  cat <<EOF
${CYAN}${BOLD}MindWall 缁堢鍛戒护闈㈡澘 v2.0${NC}

鐙珛妯″紡閮ㄧ讲锛屼笉褰卞搷 Nginx / PM2 / 鍏朵粬鏈嶅姟銆?
${BOLD}鐢ㄦ硶:${NC}
  mw                      鑷姩妯″紡锛堝凡閮ㄧ讲鍒欐洿鏂帮紝鏈儴缃插垯瀹夎锛?  mw deploy [鍙傛暟]        棣栨閮ㄧ讲 / 瀹屾暣閮ㄧ讲
  mw update [鍙傛暟]        蹇€熸洿鏂?  mw status               鏌ョ湅杩愯鐘舵€?  mw restart              閲嶅惎鎵€鏈夋湇鍔?  mw stop                 鍋滄鎵€鏈夋湇鍔?  mw logs [api|web]       鏌ョ湅瀹炴椂鏃ュ織锛堥粯璁?API锛?  mw backup               澶囦唤褰撳墠閰嶇疆
  mw uninstall [鍙傛暟]     鍗歌浇鏈嶅姟
  mw menu                 浜や簰鑿滃崟
  mw help                 鏌ョ湅甯姪
EOF
}

load_ports() {
  API_PORT=""
  WEB_PORT=""
  PG_PORT=""
  REDIS_PORT=""
  if [[ -f "$RUNTIME_PORTS_FILE" ]]; then
    API_PORT="$(grep -E '^API_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    WEB_PORT="$(grep -E '^WEB_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    PG_PORT="$(grep -E '^PG_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    REDIS_PORT="$(grep -E '^REDIS_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
  fi
}

is_installed() {
  [[ -f /etc/systemd/system/mindwall-api.service ]] && [[ -f "$DEPLOY_SCRIPT" ]]
}

service_status() {
  local name="$1"
  if command -v systemctl >/dev/null 2>&1; then
    if systemctl is-active --quiet "$name" 2>/dev/null; then
      echo -e "${GREEN}杩愯涓?{NC}"
    else
      echo -e "${RED}鏈繍琛?{NC}"
    fi
  else
    echo -e "${YELLOW}鏈煡${NC}"
  fi
}

run_deploy() {
  [[ -f "$DEPLOY_SCRIPT" ]] || { echo "閿欒: 缂哄皯 $DEPLOY_SCRIPT"; exit 1; }
  exec bash "$DEPLOY_SCRIPT" "$@"
}

run_update() {
  [[ -f "$UPDATE_SCRIPT" ]] || { echo "閿欒: 缂哄皯 $UPDATE_SCRIPT"; exit 1; }
  exec bash "$UPDATE_SCRIPT" "$@"
}

run_uninstall() {
  [[ -f "$UNINSTALL_SCRIPT" ]] || { echo "閿欒: 缂哄皯 $UNINSTALL_SCRIPT"; exit 1; }
  exec bash "$UNINSTALL_SCRIPT" "$@"
}

show_status() {
  load_ports
  echo
  echo -e "${CYAN}${BOLD}MindWall v$(project_version) 鐘舵€?{NC}"
  echo -e "鐩綍: $ROOT_DIR"
  echo

  echo -e "  mindwall-api:  $(service_status mindwall-api)   绔彛: ${API_PORT:-鏈厤缃畗"
  echo -e "  mindwall-web:  $(service_status mindwall-web)   绔彛: ${WEB_PORT:-鏈厤缃畗"

  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    local pg_status="鏈繍琛? redis_status="鏈繍琛?
    docker inspect --format '{{.State.Status}}' mindwall-postgres 2>/dev/null | grep -q running && pg_status="${GREEN}杩愯涓?{NC}"
    docker inspect --format '{{.State.Status}}' mindwall-redis 2>/dev/null | grep -q running && redis_status="${GREEN}杩愯涓?{NC}"
    echo -e "  PostgreSQL:    $pg_status   绔彛: ${PG_PORT:-鏈厤缃畗"
    echo -e "  Redis:         $redis_status   绔彛: ${REDIS_PORT:-鏈厤缃畗"
  fi

  echo
  if [[ -n "${WEB_PORT:-}" ]]; then
    local host; host="$(hostname -I 2>/dev/null | awk '{print $1}' || echo '127.0.0.1')"
    echo -e "  Web 鍦板潃: ${CYAN}http://${host}:${WEB_PORT}${NC}"
  fi
  echo
}

show_logs() {
  if ! command -v journalctl >/dev/null 2>&1; then
    echo "閿欒: 绯荤粺涓嶆敮鎸?journalctl" >&2; exit 1
  fi
  local target="${1:-api}"
  case "$target" in
    api) exec journalctl -u mindwall-api -f ;;
    web) exec journalctl -u mindwall-web -f ;;
    *)   echo "鐢ㄦ硶: mw logs [api|web]"; exit 1 ;;
  esac
}

do_restart() {
  echo -e "${CYAN}閲嶅惎 MindWall 鏈嶅姟...${NC}"
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl restart mindwall-api 2>/dev/null || true
    sudo systemctl restart mindwall-web 2>/dev/null || true
    sleep 2
    show_status
  else
    echo "閿欒: 绯荤粺涓嶆敮鎸?systemctl" >&2; exit 1
  fi
}

do_stop() {
  echo -e "${CYAN}鍋滄 MindWall 鏈嶅姟...${NC}"
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl stop mindwall-api 2>/dev/null || true
    sudo systemctl stop mindwall-web 2>/dev/null || true
    echo -e "${GREEN}宸插仠姝?{NC}"
  else
    echo "閿欒: 绯荤粺涓嶆敮鎸?systemctl" >&2; exit 1
  fi
}

do_backup() {
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  local bak="$ROOT_DIR/.mw-runtime/backups/$ts"
  mkdir -p "$bak"
  [[ -f "$ROOT_DIR/apps/api/.env" ]] && cp "$ROOT_DIR/apps/api/.env" "$bak/api.env"
  [[ -f "$ROOT_DIR/apps/web/.env.production.local" ]] && cp "$ROOT_DIR/apps/web/.env.production.local" "$bak/web.env.production.local"
  [[ -f "$RUNTIME_PORTS_FILE" ]] && cp "$RUNTIME_PORTS_FILE" "$bak/ports.env"
  echo -e "${GREEN}宸插浠藉埌: $bak${NC}"
}

show_menu() {
  while true; do
    echo
    echo -e "${CYAN}${BOLD}鈺愨晲鈺愨晲鈺愨晲鈺?MindWall 绠＄悊鑿滃崟 鈺愨晲鈺愨晲鈺愨晲鈺?{NC}"
    echo -e "  ${BOLD}1)${NC} 鑷姩鎵ц锛堟帹鑽愶級"
    echo -e "  ${BOLD}2)${NC} 棣栨閮ㄧ讲"
    echo -e "  ${BOLD}3)${NC} 蹇€熸洿鏂?
    echo -e "  ${BOLD}4)${NC} 鏌ョ湅鐘舵€?
    echo -e "  ${BOLD}5)${NC} 閲嶅惎鏈嶅姟"
    echo -e "  ${BOLD}6)${NC} 鍋滄鏈嶅姟"
    echo -e "  ${BOLD}7)${NC} 鏌ョ湅 API 鏃ュ織"
    echo -e "  ${BOLD}8)${NC} 鏌ョ湅 Web 鏃ュ織"
    echo -e "  ${BOLD}9)${NC} 澶囦唤閰嶇疆"
    echo -e "  ${BOLD}10)${NC} 鍗歌浇鏈嶅姟"
    echo -e "  ${BOLD}0)${NC} 閫€鍑?
    echo -e "${CYAN}${BOLD}鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲鈺愨晲${NC}"
    read -r -p "璇烽€夋嫨 [0-10]: " choice
    case "$choice" in
      1)  bash "$ROOT_DIR/mw" auto ;;
      2)  bash "$ROOT_DIR/mw" deploy ;;
      3)  bash "$ROOT_DIR/mw" update ;;
      4)  show_status ;;
      5)  do_restart ;;
      6)  do_stop ;;
      7)  show_logs api ;;
      8)  show_logs web ;;
      9)  do_backup ;;
      10) bash "$ROOT_DIR/mw" uninstall ;;
      0)  exit 0 ;;
      *)  echo -e "${YELLOW}鏃犳晥閫夐」${NC}" ;;
    esac
  done
}

case "$COMMAND" in
  auto)
    if is_installed; then
      echo -e "妫€娴嬪埌宸查儴缃诧紝鎵ц${GREEN}蹇€熸洿鏂?{NC}..."
      run_update "$@"
    else
      echo -e "妫€娴嬪埌鏈儴缃诧紝鎵ц${GREEN}棣栨閮ㄧ讲${NC}..."
      run_deploy "$@"
    fi
    ;;
  deploy|install) run_deploy "$@" ;;
  update)         run_update "$@" ;;
  uninstall)      run_uninstall "$@" ;;
  status)         show_status ;;
  restart)        do_restart ;;
  stop)           do_stop ;;
  logs)           show_logs "${1:-api}" ;;
  backup)         do_backup ;;
  menu)           show_menu ;;
  help|-h|--help) usage ;;
  *) echo -e "${RED}閿欒: 鏈瘑鍒懡浠?$COMMAND${NC}"; usage; exit 1 ;;
esac
