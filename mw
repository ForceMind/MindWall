#!/usr/bin/env bash
# MindWall 终端命令面板 v2.0
# 学习自 Minimal-Server-Deploy 的 zt.sh 菜单式管理
set -euo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

SELF="${BASH_SOURCE[0]:-$0}"
if command -v readlink >/dev/null 2>&1; then
  SELF="$(readlink -f "$SELF" 2>/dev/null || echo "$SELF")"
fi

ROOT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
DEPLOY_SCRIPT="$ROOT_DIR/deploy.sh"
UPDATE_SCRIPT="$ROOT_DIR/update.sh"
UNINSTALL_SCRIPT="$ROOT_DIR/uninstall.sh"
VERSION_FILE="$ROOT_DIR/VERSION"
RUNTIME_PORTS_FILE="$ROOT_DIR/.mw-runtime/ports.env"

COMMAND="${1:-auto}"
if [[ $# -gt 0 ]]; then shift; fi

# 兼容: mw --yes => mw auto --yes
if [[ "${COMMAND#--}" != "$COMMAND" ]]; then
  set -- "$COMMAND" "$@"
  COMMAND="auto"
fi

project_version() {
  [[ -f "$VERSION_FILE" ]] && tr -d '[:space:]' < "$VERSION_FILE" || echo "未知"
}

usage() {
  cat <<EOF
${CYAN}${BOLD}MindWall 终端命令面板 v2.0${NC}

独立模式部署，不影响 Nginx / PM2 / 其他服务。

${BOLD}用法:${NC}
  mw                      自动模式（已部署则更新，未部署则安装）
  mw deploy [参数]        首次部署 / 完整部署
  mw update [参数]        快速更新
  mw status               查看运行状态
  mw restart              重启所有服务
  mw stop                 停止所有服务
  mw logs [api|web]       查看实时日志（默认 API）
  mw backup               备份当前配置
  mw uninstall [参数]     卸载服务
  mw menu                 交互菜单
  mw help                 查看帮助
EOF
}

load_ports() {
  API_PORT=""
  WEB_PORT=""
  PG_PORT=""
  REDIS_PORT=""
  if [[ -f "$RUNTIME_PORTS_FILE" ]]; then
    API_PORT="$(grep -E '^API_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    WEB_PORT="$(grep -E '^WEB_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    PG_PORT="$(grep -E '^PG_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
    REDIS_PORT="$(grep -E '^REDIS_PORT=' "$RUNTIME_PORTS_FILE" | tail -1 | cut -d= -f2- || true)"
  fi
}

is_installed() {
  [[ -f /etc/systemd/system/mindwall-api.service ]] && [[ -f "$DEPLOY_SCRIPT" ]]
}

service_status() {
  local name="$1"
  if command -v systemctl >/dev/null 2>&1; then
    if systemctl is-active --quiet "$name" 2>/dev/null; then
      echo -e "${GREEN}运行中${NC}"
    else
      echo -e "${RED}未运行${NC}"
    fi
  else
    echo -e "${YELLOW}未知${NC}"
  fi
}

run_deploy() {
  [[ -f "$DEPLOY_SCRIPT" ]] || { echo "错误: 缺少 $DEPLOY_SCRIPT"; exit 1; }
  exec bash "$DEPLOY_SCRIPT" "$@"
}

run_update() {
  [[ -f "$UPDATE_SCRIPT" ]] || { echo "错误: 缺少 $UPDATE_SCRIPT"; exit 1; }
  exec bash "$UPDATE_SCRIPT" "$@"
}

run_uninstall() {
  [[ -f "$UNINSTALL_SCRIPT" ]] || { echo "错误: 缺少 $UNINSTALL_SCRIPT"; exit 1; }
  exec bash "$UNINSTALL_SCRIPT" "$@"
}

show_status() {
  load_ports
  echo
  echo -e "${CYAN}${BOLD}MindWall v$(project_version) 状态${NC}"
  echo -e "目录: $ROOT_DIR"
  echo

  echo -e "  mindwall-api:  $(service_status mindwall-api)   端口: ${API_PORT:-未配置}"
  echo -e "  mindwall-web:  $(service_status mindwall-web)   端口: ${WEB_PORT:-未配置}"

  if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
    local pg_status="未运行" redis_status="未运行"
    docker inspect --format '{{.State.Status}}' mindwall-postgres 2>/dev/null | grep -q running && pg_status="${GREEN}运行中${NC}"
    docker inspect --format '{{.State.Status}}' mindwall-redis 2>/dev/null | grep -q running && redis_status="${GREEN}运行中${NC}"
    echo -e "  PostgreSQL:    $pg_status   端口: ${PG_PORT:-未配置}"
    echo -e "  Redis:         $redis_status   端口: ${REDIS_PORT:-未配置}"
  fi

  echo
  if [[ -n "${WEB_PORT:-}" ]]; then
    local host; host="$(hostname -I 2>/dev/null | awk '{print $1}' || echo '127.0.0.1')"
    echo -e "  Web 地址: ${CYAN}http://${host}:${WEB_PORT}${NC}"
  fi
  echo
}

show_logs() {
  if ! command -v journalctl >/dev/null 2>&1; then
    echo "错误: 系统不支持 journalctl" >&2; exit 1
  fi
  local target="${1:-api}"
  case "$target" in
    api) exec journalctl -u mindwall-api -f ;;
    web) exec journalctl -u mindwall-web -f ;;
    *)   echo "用法: mw logs [api|web]"; exit 1 ;;
  esac
}

do_restart() {
  echo -e "${CYAN}重启 MindWall 服务...${NC}"
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl restart mindwall-api 2>/dev/null || true
    sudo systemctl restart mindwall-web 2>/dev/null || true
    sleep 2
    show_status
  else
    echo "错误: 系统不支持 systemctl" >&2; exit 1
  fi
}

do_stop() {
  echo -e "${CYAN}停止 MindWall 服务...${NC}"
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl stop mindwall-api 2>/dev/null || true
    sudo systemctl stop mindwall-web 2>/dev/null || true
    echo -e "${GREEN}已停止${NC}"
  else
    echo "错误: 系统不支持 systemctl" >&2; exit 1
  fi
}

do_backup() {
  local ts; ts="$(date +%Y%m%d-%H%M%S)"
  local bak="$ROOT_DIR/.mw-runtime/backups/$ts"
  mkdir -p "$bak"
  [[ -f "$ROOT_DIR/apps/api/.env" ]] && cp "$ROOT_DIR/apps/api/.env" "$bak/api.env"
  [[ -f "$ROOT_DIR/apps/web/.env.production.local" ]] && cp "$ROOT_DIR/apps/web/.env.production.local" "$bak/web.env.production.local"
  [[ -f "$RUNTIME_PORTS_FILE" ]] && cp "$RUNTIME_PORTS_FILE" "$bak/ports.env"
  echo -e "${GREEN}已备份到: $bak${NC}"
}

show_menu() {
  while true; do
    echo
    echo -e "${CYAN}${BOLD}═══════ MindWall 管理菜单 ═══════${NC}"
    echo -e "  ${BOLD}1)${NC} 自动执行（推荐）"
    echo -e "  ${BOLD}2)${NC} 首次部署"
    echo -e "  ${BOLD}3)${NC} 快速更新"
    echo -e "  ${BOLD}4)${NC} 查看状态"
    echo -e "  ${BOLD}5)${NC} 重启服务"
    echo -e "  ${BOLD}6)${NC} 停止服务"
    echo -e "  ${BOLD}7)${NC} 查看 API 日志"
    echo -e "  ${BOLD}8)${NC} 查看 Web 日志"
    echo -e "  ${BOLD}9)${NC} 备份配置"
    echo -e "  ${BOLD}10)${NC} 卸载服务"
    echo -e "  ${BOLD}0)${NC} 退出"
    echo -e "${CYAN}${BOLD}══════════════════════════════════${NC}"
    read -r -p "请选择 [0-10]: " choice
    case "$choice" in
      1)  bash "$ROOT_DIR/mw" auto ;;
      2)  bash "$ROOT_DIR/mw" deploy ;;
      3)  bash "$ROOT_DIR/mw" update ;;
      4)  show_status ;;
      5)  do_restart ;;
      6)  do_stop ;;
      7)  show_logs api ;;
      8)  show_logs web ;;
      9)  do_backup ;;
      10) bash "$ROOT_DIR/mw" uninstall ;;
      0)  exit 0 ;;
      *)  echo -e "${YELLOW}无效选项${NC}" ;;
    esac
  done
}

case "$COMMAND" in
  auto)
    if is_installed; then
      echo -e "检测到已部署，执行${GREEN}快速更新${NC}..."
      run_update "$@"
    else
      echo -e "检测到未部署，执行${GREEN}首次部署${NC}..."
      run_deploy "$@"
    fi
    ;;
  deploy|install) run_deploy "$@" ;;
  update)         run_update "$@" ;;
  uninstall)      run_uninstall "$@" ;;
  status)         show_status ;;
  restart)        do_restart ;;
  stop)           do_stop ;;
  logs)           show_logs "${1:-api}" ;;
  backup)         do_backup ;;
  menu)           show_menu ;;
  help|-h|--help) usage ;;
  *) echo -e "${RED}错误: 未识别命令 $COMMAND${NC}"; usage; exit 1 ;;
esac
